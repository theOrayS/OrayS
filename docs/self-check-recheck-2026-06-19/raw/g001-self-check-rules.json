{
  "rule_count": 13,
  "rules": [
    {
      "group": "禁止行为1",
      "number": 1,
      "text": "对某些测试程序名称或二进制特征进行特殊判断"
    },
    {
      "group": "禁止行为1",
      "number": 2,
      "text": "对特定syscall参数组合、输入数据、目录结构进行硬编码"
    },
    {
      "group": "禁止行为1",
      "number": 3,
      "text": "仅针对高分测试集合实现局部功能，而故意忽略通用语义"
    },
    {
      "group": "禁止行为1",
      "number": 4,
      "text": "利用测评系统环境差异、固定路径、固定时间、固定顺序进行投机"
    },
    {
      "group": "禁止行为1",
      "number": 5,
      "text": "为通过测试破坏 Linux syscall 兼容语义或内核基本安全边界"
    },
    {
      "group": "禁止行为1",
      "number": 6,
      "text": "通过非通用方式绕过真实的进程、内存、文件系统或同步机制"
    },
    {
      "group": "禁止行为1",
      "number": 7,
      "text": "其他以猜测测例、适配测例、硬编码测例为目标的投机性实现或评审委员会认定的违规测试行为"
    },
    {
      "group": "禁止行为2",
      "number": 1,
      "text": "牺牲Linux syscall主要功能的兼容语义换取速度"
    },
    {
      "group": "禁止行为2",
      "number": 2,
      "text": "对特定测试输入硬编码结果"
    },
    {
      "group": "禁止行为2",
      "number": 3,
      "text": "跳过必要的权限检查、资源检查或错误处理"
    },
    {
      "group": "禁止行为2",
      "number": 4,
      "text": "在隐藏条件下可能导致内核崩溃或数据错误"
    },
    {
      "group": "禁止行为2",
      "number": 5,
      "text": "只对固定测例有效、对一般程序无效的优化"
    },
    {
      "group": "禁止行为2",
      "number": 6,
      "text": "其他不符合正确性、通用性和可解释性的优化"
    }
  ]
