          <mxGeometry x="420" y="675" width="360" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="i_other" value="其他 IPC&#xa;pipe / POSIX mq / SysV msg / SysV sem / socketpair" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="90" y="310" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="i_exit" value="进程生命周期闭环&#xa;fork retain_attachments&#xa;teardown release_process_attachments" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="870" y="675" width="240" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="i_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#6c8ebf" edge="1" parent="1" source="i_create" target="i_active">
