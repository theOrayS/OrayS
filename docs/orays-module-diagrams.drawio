  <diagram id="orays-ipc-shm" name="05 IPC 与共享内存">
    <mxGraphModel dx="1200" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="i_title" value="OrayS IPC 与 System V 共享内存生命周期" style="text;html=1;strokeColor=none;fillColor=none;fontSize=22;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="300" y="25" width="600" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="i_create" value="sys_shmget&#xa;分配页 / 初始化 SysvShmSegment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="90" width="360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="i_active" value="活动表 table()&#xa;可被 shmget / shmat / IPC_STAT 查找" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f2df;strokeColor=#82b366;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="420" y="200" width="360" height="70" as="geometry"/>
        </mxCell>
