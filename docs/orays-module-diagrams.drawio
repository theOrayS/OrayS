          <mxGeometry x="420" y="310" width="360" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="i_rmid" value="sys_shmctl(IPC_RMID)&#xa;立即从活动表移除 shmid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="440" width="360" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="i_removed" value="removed_segments()&#xa;仍有 attach 时保留 backing pages&#xa;不允许新的 shmat 查找" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="420" y="550" width="360" height="85" as="geometry"/>
        </mxCell>
