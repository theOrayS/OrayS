    {
      "id": "smoke.la64.abi",
      "title": "LoongArch64 repository-contained Linux ABI smoke",
      "category": "runtime-smoke",
      "architectures": [
        "loongarch64"
      ],
      "runner_id": "qemu-smoke-v1",
      "evidence_level": "runtime_semantic",
      "policy": "required",
      "timeout_seconds": 120,
      "requires": [
        "make",
        "qemu-la64"
      ],
      "depends_on": [
        "build.la64.smoke-harness"
      ],
      "command": [
        "make",
        "pr3-smoke-run-la-raw"
      ],
      "classifier": {
        "kind": "marker_protocol",
        "ordered_markers": [
          "PR3_SMOKE_V1 HARNESS_START arch={arch}",
          "PR3_SMOKE_V1 USER_START arch={arch}",
          "PR3_SMOKE_V1 ASSERT write PASS arch={arch}",
          "PR3_SMOKE_V1 ASSERT getpid PASS arch={arch}",
          "PR3_SMOKE_V1 ASSERT uname_sysname PASS arch={arch}",
          "PR3_SMOKE_V1 ASSERT uname_machine PASS arch={arch}",
          "PR3_SMOKE_V1 USER_PASS arch={arch}",
          "PR3_SMOKE_V1 HARNESS_PASS arch={arch} status=0",
          "PR3_SMOKE_V1 SHUTDOWN arch={arch}"
        ],
        "fatal_patterns": [
          "^PR3_SMOKE_V1 (?:USER|HARNESS)_FAIL\\b",
          "\\b(?:panic|panicked)\\b",
          "\\b(?:Unhandled trap|fatal trap|kernel trap|InstructionNotExist)\\b",
          "\\bENOSYS\\b",
          "\\b(?:TIMEOUT|timed out)\\b"
        ],
        "boot_marker": "PR3_SMOKE_V1 HARNESS_START arch={arch}"
      },
      "provenance": [
        "Makefile",
        "user/shell/Cargo.toml",
        "user/shell/build.rs",
        "user/shell/runtime_smoke/semantic_smoke.ld",
        "user/shell/runtime_smoke/semantic_smoke.rs",
        "user/shell/src/main.rs",
        "user/shell/src/semantic_smoke.rs"
      ],
      "environment": {
        "PR3_EVIDENCE_SUPERVISED": "1"
      }
    },
